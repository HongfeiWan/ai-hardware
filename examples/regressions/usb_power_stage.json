{
  "schema_version": "0.1.0",
  "tasks": [
    {
      "id": "usb_power_stage_vout_collapse",
      "board": "examples/boards/usb_power_stage.yaml",
      "symptom": "3V3 rail does not stay up after USB input is applied.",
      "expected": {
        "severity": ["warning", "fault"],
        "summary_contains": "VOUT_3V3",
        "next_action_net": "SW_NODE"
      }
    },
    {
      "id": "usb_power_stage_ripple_check",
      "board": "examples/boards/usb_power_stage.yaml",
      "symptom": "3V3 rail ripple appears excessive during startup.",
      "expected": {
        "severity": "warning",
        "summary_contains": "ripple",
        "next_action_net": "SW_NODE"
      }
    },
    {
      "id": "usb_power_stage_vout_overvoltage",
      "board": "examples/boards/usb_power_stage.yaml",
      "symptom": "3V3 rail overvoltage exceeds the configured maximum during startup.",
      "expected": {
        "severity": "critical",
        "summary_contains": "above",
        "next_action_type": "stop"
      }
    },
    {
      "id": "usb_power_stage_enable_low",
      "board": "examples/boards/usb_power_stage.yaml",
      "symptom": "3V3 rail is disabled because EN_3V3 enable low is not asserted.",
      "tool_calls": [
        {
          "name": "measure_dc_voltage",
          "arguments": {
            "net": "EN_3V3"
          }
        },
        {
          "name": "capture_waveform",
          "arguments": {
            "net": "VOUT_3V3",
            "sample_count": 64
          }
        }
      ],
      "expected": {
        "severity": "fault",
        "summary_contains": "EN_3V3",
        "next_action_net": "EN_3V3",
        "next_action_type": "inspect_component"
      }
    },
    {
      "id": "usb_power_stage_power_good_low",
      "board": "examples/boards/usb_power_stage.yaml",
      "symptom": "3V3 output is present but PG_3V3 power good low remains deasserted.",
      "tool_calls": [
        {
          "name": "measure_dc_voltage",
          "arguments": {
            "net": "VOUT_3V3"
          }
        },
        {
          "name": "capture_logic",
          "arguments": {
            "net": "PG_3V3",
            "sample_count": 64
          }
        }
      ],
      "expected": {
        "severity": "fault",
        "summary_contains": "PG_3V3",
        "next_action_net": "PG_3V3",
        "next_action_type": "inspect_component"
      }
    },
    {
      "id": "usb_power_stage_vout_short_to_ground",
      "board": "examples/boards/usb_power_stage.yaml",
      "symptom": "3V3 rail appears shorted to ground before power is applied.",
      "tool_calls": [
        {
          "name": "measure_impedance",
          "arguments": {
            "net": "VOUT_3V3"
          }
        }
      ],
      "expected": {
        "severity": "critical",
        "summary_contains": "shorted",
        "next_action_type": "stop"
      }
    },
    {
      "id": "usb_power_stage_switch_node_inactive",
      "board": "examples/boards/usb_power_stage.yaml",
      "symptom": "3V3 rail is low and SW_NODE not switching with no pulses.",
      "tool_calls": [
        {
          "name": "measure_dc_voltage",
          "arguments": {
            "net": "EN_3V3"
          }
        },
        {
          "name": "capture_waveform",
          "arguments": {
            "net": "SW_NODE",
            "sample_count": 64,
            "confirm": true
          }
        }
      ],
      "expected": {
        "severity": "fault",
        "summary_contains": "SW_NODE",
        "next_action_net": "SW_NODE",
        "next_action_type": "inspect_component"
      }
    },
    {
      "id": "usb_power_stage_reset_stuck_low",
      "board": "examples/boards/usb_power_stage.yaml",
      "symptom": "3V3 rail is present but MCU_RESET_N reset stuck low and not released.",
      "tool_calls": [
        {
          "name": "measure_dc_voltage",
          "arguments": {
            "net": "VOUT_3V3"
          }
        },
        {
          "name": "capture_logic",
          "arguments": {
            "net": "MCU_RESET_N",
            "sample_count": 64
          }
        }
      ],
      "expected": {
        "severity": "fault",
        "summary_contains": "MCU_RESET_N",
        "next_action_net": "MCU_RESET_N",
        "next_action_type": "inspect_component"
      }
    },
    {
      "id": "usb_power_stage_clock_missing",
      "board": "examples/boards/usb_power_stage.yaml",
      "symptom": "3V3 rail is present but MCU_CLK clock missing and crystal not oscillating.",
      "tool_calls": [
        {
          "name": "measure_dc_voltage",
          "arguments": {
            "net": "VOUT_3V3"
          }
        },
        {
          "name": "capture_logic",
          "arguments": {
            "net": "MCU_CLK",
            "sample_count": 64
          }
        }
      ],
      "expected": {
        "severity": "fault",
        "summary_contains": "MCU_CLK",
        "next_action_net": "MCU_CLK",
        "next_action_type": "inspect_component"
      }
    },
    {
      "id": "usb_power_stage_i2c_bus_held_low",
      "board": "examples/boards/usb_power_stage.yaml",
      "symptom": "3V3 rail is present but I2C bus held low on I2C_SCL by an attached device.",
      "tool_calls": [
        {
          "name": "measure_dc_voltage",
          "arguments": {
            "net": "VOUT_3V3"
          }
        },
        {
          "name": "capture_logic",
          "arguments": {
            "net": "I2C_SCL",
            "sample_count": 64
          }
        }
      ],
      "expected": {
        "severity": "fault",
        "summary_contains": "I2C_SCL",
        "next_action_net": "I2C_SCL",
        "next_action_type": "inspect_component"
      }
    },
    {
      "id": "usb_power_stage_ldo_output_abnormal",
      "board": "examples/boards/usb_power_stage.yaml",
      "symptom": "3V3 rail is present and LDO input is normal but 1V8 LDO output abnormal and 1V8 low.",
      "tool_calls": [
        {
          "name": "measure_dc_voltage",
          "arguments": {
            "net": "VOUT_3V3"
          }
        },
        {
          "name": "measure_dc_voltage",
          "arguments": {
            "net": "VDD_1V8"
          }
        }
      ],
      "expected": {
        "severity": "fault",
        "summary_contains": "VDD_1V8",
        "next_action_net": "VDD_1V8",
        "next_action_type": "inspect_component"
      }
    }
  ]
}
